{
  "name": "stillness-pwa",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.10"
  },
  "scripts": {
    "dev": "waku dev",
    "build": "waku build",
    "start": "waku start --port ${PORT:-8080} --host ${HOST:-127.0.0.1}",
    "type-check": "tsc --noEmit",
    "test": "node --test --experimental-strip-types tests/*.test.ts",
    "test:browser": "pnpm run build && node scripts/browser-smoke.mjs",
    "typegen": "waku router typegen"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "0.10.35",
    "hono": "^4.12.14",
    "react": "~19.2.6",
    "react-dom": "~19.2.6",
    "react-server-dom-webpack": "~19.2.6",
    "waku": "1.0.0-beta.4"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "typescript": "^6.0.3"
  }
}
